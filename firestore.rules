rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isBot() {
      return isSignedIn()
        && request.auth.uid == 'SuTqNzX5A5hwmDnMh7wCK4aHEss1';
    }

    match /briefings/{date} {
      allow read: if isSignedIn();
      allow write: if isBot();
    }

    match /rustTasks/{id} {
      allow read: if isSignedIn();
      allow write: if isBot();
    }

    match /rustReadings/{id} {
      allow read: if isSignedIn();
      allow write: if isBot();
    }

    match /agentItems/{id} {
      allow read: if isSignedIn();
      allow write: if isBot();
    }

    match /businessIdeas/{id} {
      allow read: if isSignedIn();
      allow write: if isBot();
    }

    match /aiTips/{id} {
      allow read: if isSignedIn();
      allow write: if isBot();
    }
  }
}
